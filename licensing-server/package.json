{
  "name": "softglaze-licensing-server",
  "version": "0.1.0",
  "private": true,
  "description": "SoftGlaze multi-tenant licensing + payment backend. Phase 1: tenant provisioning, Stripe test-mode checkout/webhook, Ed25519 license leases.",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "provision": "node scripts/provision-tenant.js",
    "test": "node --test \"test/**/*.test.js\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "engines": {
    "node": ">=18"
  }
}
