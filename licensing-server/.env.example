# --- SoftGlaze Licensing Server — environment ---
# Copy to .env and fill in. NEVER commit .env.

# Postgres connection string (Prisma datasource).
DATABASE_URL="postgresql://user:pass@localhost:5432/softglaze_licensing?schema=public"

# 32-byte base64 master key. Encrypts tenant payment secrets AND tenant private
# keys at rest (AES-256-GCM). Losing/rotating this invalidates all sealed values.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=""

# HTTP
PORT=8787
# The public origin the desktop apps + payment webhooks reach this server at.
PUBLIC_BASE_URL="http://localhost:8787"

# License lease lifetime in days. The desktop app refreshes within this window
# while online; offline it runs on the cached lease until it expires, then nags.
LEASE_DAYS=7
