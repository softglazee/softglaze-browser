generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProxyType {
  HTTP
  SOCKS5
}

enum SystemProxyBehavior {
  DIRECT
  PROFILE_PROXY
  SYSTEM_PROXY
}

model Proxy {
  id        Int       @id @default(autoincrement())
  name      String
  type      ProxyType @default(HTTP)
  host      String
  port      Int
  username  String?
  password  String?
  rotationUrl String? // optional vendor IP-rotation trigger link (mobile/residential proxies)
  createdAt DateTime  @default(now())

  // Health (populated by the proxy checker)
  lastStatus    String? // 'ok' | 'fail'
  lastLatencyMs Int?
  lastCountry   String?
  lastRegion    String? // verified exit region/state (for auto-grouping)
  lastCity      String? // verified exit city (for auto-grouping)
  lastCheckedAt DateTime?

  ownerMemberId Int? // member who added this proxy (for per-member quotas)

  // Optional category/group (USA, UK, Japan, …) for organizing the pool and for
  // targeting a batch at "proxies from group X". Cleared (SetNull) if the group
  // is deleted so the proxy itself survives.
  proxyGroupId Int?
  provider     String? // origin tag: 'apify' | 'shopsocks5' | 'smartproxyorg' | 'custom' | … (for auto-grouping)

  profiles   Profile[]
  proxyGroup ProxyGroup? @relation(fields: [proxyGroupId], references: [id], onDelete: SetNull)

  @@index([host, port])
  @@index([createdAt])
  @@index([ownerMemberId])
  @@index([proxyGroupId])
  @@unique([type, host, port, username])
}

// Proxy categories/folders (e.g. "USA Proxies", "UK", "Japan"). A proxy belongs to
// at most one group; profiles can be batch-created from a chosen group's proxies.
model ProxyGroup {
  id        Int      @id @default(autoincrement())
  name      String
  color     String?  @default("#3b82f6")
  ownerMemberId Int?
  createdAt DateTime @default(now())

  proxies Proxy[]

  @@index([createdAt])
  @@index([ownerMemberId])
}

// Time-series proxy health (one row per check) for latency-over-time + status
// history charts. Appended by persistProxyHealth; pruned to ~30 days at startup.
model ProxyHealthEvent {
  id        Int      @id @default(autoincrement())
  proxyId   Int
  ts        DateTime @default(now())
  status    String // 'ok' | 'fail'
  latencyMs Int?
  country   String?

  @@index([proxyId, ts])
}

model Group {
  id        Int      @id @default(autoincrement())
  name      String
  color     String?  @default("#3b82f6")
  createdAt DateTime @default(now())

  profiles Profile[]

  @@index([createdAt])
}

model Template {
  id        Int      @id @default(autoincrement())
  name      String
  dataJson  String // JSON snapshot of profile config fields
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  profileId Int // 0 = system/security event with no associated profile (see logAudit)
  memberId  Int?
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
  @@index([memberId, createdAt])
  @@index([action, createdAt])
}

model Setting {
  key   String @id
  value String
}

// Session restore + crash recovery. One row per profile that is (or was) running.
// status stays 'running' across a clean quit OR a crash so the next launch can
// offer to restore it; a deliberate user-close marks it 'closed'.
model SessionState {
  id           Int      @id @default(autoincrement())
  profileId    Int      @unique
  engine       String   @default("chrome") // chrome | firefox
  status       String   @default("running") // running | closed
  launchedAt   DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  crashCount   Int      @default(0)
  lastExitCode Int?
  updatedAt    DateTime @updatedAt

  @@index([status])
}

model Member {
  id           Int       @id @default(autoincrement())
  name         String
  email        String?
  role         String    @default("OPERATOR") // OWNER | ADMIN | MANAGER | OPERATOR
  color        String?   @default("#3DC6DA")
  initials     String?
  avatarUrl    String? // base64 data URI or local file path for the profile picture
  pinHash      String?
  pinSalt      String?
  status       String    @default("active") // active | suspended | banned
  banReason    String? // why the owner tree was banned (trial/grace lapsed, or admin action)

  // Hierarchy + per-member auth + permissions (RBAC)
  parentMemberId  Int? // who invited/created this member (null = top of a tree)
  passwordHash    String? // per-member login (sub-members sign in independently)
  passwordSalt    String?
  permissionsJson String? // JSON: limits (maxProfiles/…) + feature flags granted by parent
  inviteCode      String? // pending-invite code, consumed on register
  inviteStatus    String?   @default("active") // pending | active

  createdAt    DateTime  @default(now())
  lastActiveAt DateTime?

  @@index([createdAt])
  @@index([parentMemberId])
  @@index([inviteCode])
}

model License {
  id            Int       @id @default(autoincrement())
  ownerMemberId Int?
  type          String    @default("trial") // trial | paid
  tier          String?   @default("pro") // pro | enterprise (recorded plan/version)
  purchaseCode  String?
  status        String    @default("active") // active | expired
  trialEndsAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([ownerMemberId])
}

model Invoice {
  id            Int       @id @default(autoincrement())
  ownerMemberId Int? // owner tree this invoice belongs to
  memberId      Int? // member who paid (optional)
  amount        String    @default("0")
  currency      String    @default("USD")
  provider      String? // cryptomus | stripe | paypal | wise | manual
  status        String    @default("paid") // paid | pending | refunded
  reference     String? // purchase code / transaction id
  tier          String? // pro | enterprise
  months        Int?      @default(1)
  note          String?
  source        String    @default("manual") // auto (captured from a payment) | manual
  issuedAt      DateTime  @default(now())
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([ownerMemberId])
  @@index([createdAt])
}

model IpProvider {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  apiKey       String?
  secretKey    String?
  status       String   @default("DISABLED") // ENABLED | DISABLED
  referralLink String?
  updatedAt    DateTime @updatedAt @default(now())
}

// --- Softglaze Pro: No-Code Macro Automation ---
model Macro {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  stepsJson   String   @default("[]") // JSON array of the visual workflow steps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  @@index([updatedAt])
}

// --- Softglaze Pro: Local Developer API tokens ---
// Only the SHA-256 hash of a token is stored; the plaintext `sg_…` value is
// shown to the user exactly once at generation time and never persisted.
model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tokenHash])
}

// --- Team Extensions: Chrome Web Store extensions downloaded as raw .crx,
// unzipped locally, and mounted into launched profiles via --load-extension. ---
model Extension {
  id        String   @id @default(uuid())
  name      String
  chromeId  String   @unique // 32-char Chrome Web Store ID
  version   String?
  localPath String // absolute path to the unzipped extension folder
  isGlobal  Boolean  @default(true) // inject into every launched profile
  createdAt DateTime @default(now())

  @@index([isGlobal])
}

// --- Identity Data Vault: personas/identities for the Smart Autofill engine ---
// A workspace-global vault of demo registration identities. `usedOnUrls` is a
// JSON array of hostnames the persona has already been used on, so the in-page
// autofill widget stops offering it on those sites. Passwords are stored as a
// plaintext column (the autofill engine must type them verbatim); the optional
// whole-DB at-rest encryption covers them at rest.
model PersonaData {
  id           String   @id @default(uuid())
  label        String? // optional batch label, e.g. "US Gen Z Batch"
  firstName    String
  lastName     String
  email        String
  username     String
  password     String
  phone        String?
  dateOfBirth  String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  country      String?
  company      String?
  usedOnUrls   String   @default("[]") // JSON array of hostnames already used
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt @default(now())

  @@index([createdAt])
  @@index([email])
}

model Profile {
  id                  Int                 @id @default(autoincrement())
  title               String
  proxyId             Int?
  proxyInfoString     String?
  notes               String?
  tagManagement       Int                 @default(0)
  groupId             Int?
  tags                String? // JSON array of tag strings
  ownerMemberId       Int?
  assignedMemberId    Int?
  lastUsedAt          DateTime?
  launchCount         Int                 @default(0)
  systemProxyBehavior SystemProxyBehavior @default(PROFILE_PROXY)
  dataDirName         String              @unique

  // Identity / environment
  browserCore      String?
  browserBrand     String? // Chromium-family identity: Chrome|Edge|Brave|Opera|Vivaldi|Yandex
  browserVersion   String?
  os               String?
  osVersion        String?
  deviceClass      String? @default("desktop") // "desktop" | "mobile" (Android, CDP-emulated)
  userAgent        String? @default("Auto")
  startupUrls      String?
  platformAccounts String? // JSON string

  // Softglaze Premium — native 2FA vault. Base32 TOTP secret seed for the
  // account this profile signs into; used to generate live 6-digit codes.
  twoFactorSeed String?

  // WebRTC / timezone / geolocation
  webrtc         String?
  timezoneType   String?
  timezoneCustom String?
  locationType   String?
  locationPrompt String?
  locationLat    String?
  locationLng    String?
  locationAcc    String?

  // Language / display / resolution / fonts
  languageType      String?
  languageCustom    String?
  displayLangType   String?
  displayLangCustom String?
  resolutionType    String?
  resolutionW       String?
  resolutionH       String?
  fontsType         String?

  // Fingerprint noise toggles (real booleans)
  canvasNoise       Boolean @default(true)
  webglImageNoise   Boolean @default(true)
  audioContextNoise Boolean @default(true)
  clientRectsNoise  Boolean @default(true)
  speechVoicesNoise Boolean @default(true)
  mediaDevice       String?

  // WebGL / WebGPU
  webglMetadata String?
  webglVendor   String?
  webglRenderer String?
  webgpu        String?

  // Hardware (sent as strings from the UI)
  cpuType  String?
  cpuCores String?
  ramType  String?
  ramGb    String?

  // Device identity
  deviceNameType String?
  deviceName     String?
  macAddressType String?
  macAddress     String?

  // Privacy / network / launch
  doNotTrack           String?
  portScanProtection   String?
  hardwareAcceleration String?
  disableTls           String?
  launchArgs           String?

  // HTTP/3 (QUIC) opt-in. Default false = QUIC disabled when proxied (max stealth,
  // no unproxied-UDP leak). Enable only on trusted UDP-isolating proxies (SOCKS5).
  enableQuic Boolean @default(false)

  // Advanced (extensions / sync / browser settings)
  advancedExt         String?
  advancedSync        String?
  syncItemsJson       String? // JSON string
  advancedBrowser     String?
  browserSettingsJson String? // JSON string
  randomFingerprint   Boolean @default(false)

  // Timestamps / soft delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  proxy Proxy? @relation(fields: [proxyId], references: [id], onDelete: SetNull)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  accesses ProfileAccess[]

  @@index([proxyId])
  @@index([groupId])
  @@index([assignedMemberId])
  @@index([createdAt])
  @@index([deletedAt])
}

// Shared profile pools / resource ACLs (Phase F2). A profile is visible+usable by
// its owner and its single assignedMember (the existing model); ProfileAccess adds
// explicit many-to-many sharing on top, WITHOUT loosening the fail-closed scoping.
// level: 'use' = view + launch; 'edit' = also edit. Delete/purge stay gated by the
// existing rank-based action permissions, so a shared member can never delete.
model ProfileAccess {
  id                Int      @id @default(autoincrement())
  profileId         Int
  memberId          Int
  level             String   @default("use") // 'use' | 'edit'
  grantedByMemberId Int?
  createdAt         DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, memberId])
  @@index([memberId])
  @@index([profileId])
}