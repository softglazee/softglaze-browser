{
  "name": "softglaze-browser",
  "version": "1.0.0",
  "description": "Secure Local-First Anti-Detect Browser for LeadGen and Gaming",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "build:frontend": "vite build",
    "build:electron": "prisma generate && electron-builder --win --x64",
    "build:tenant": "node scripts/build-tenant.js",
    "check:deps": "node scripts/check-deps.js",
    "test": "node --test \"test/**/*.test.js\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.16",
    "archiver": "^5.3.2",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.4",
    "extract-zip": "^2.0.1",
    "lucide-react": "^1.18.0",
    "nodemailer": "^6.9.14",
    "proxy-agent": "^6.5.0",
    "puppeteer": "^22.15.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "png2icons": "^2.0.1",
    "prisma": "^6.19.3",
    "vite": "^8.0.16",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.softglaze.browser",
    "productName": "SoftGlaze Browser",
    "copyright": "Copyright © 2026 SoftGlaze",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "dist_installer"
    },
    "afterPack": "build/afterPack.js",
    "asarUnpack": [
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/@prisma/engines/**/*",
      "prisma/**/*"
    ],
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "prisma/**/*",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "public/logos/app.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "public/logos/macos.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "SoftGlaze Browser"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "softglazee",
        "repo": "softglaze-browser"
      }
    ]
  }
}
